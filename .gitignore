/dist
/tmp
/out-tsc
/bazel-out

# Node
/node_modules
npm-debug.log
yarn-error.log

# profiling files
chrome-profiler-events*.json

# IDEs and editors
.idea/
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# Visual Studio Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.history/*

# Miscellaneous
.npmrc
/.angular/cache
.sass-cache/
/connect.lock
/coverage
/libpeerconnection.log
testem.log
/typings

# System files
.DS_Store
Thumbs.db

# Cursor debug session logs (agent instrumentation)
.cursor/debug-*.log
debug-*.log

# Capacitor LAN sync script backup
capacitor.config.prod.backup.ts

# Android signing
android/keystore.properties
*.jks
*.keystore
!android/app/urs-pos-debug.keystore
