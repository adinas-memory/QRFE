    "@angular/service-worker": "^20.3.18",
    "@capacitor/app": "^7.1.2",
    "@capacitor/core": "^7.2.0",
    "@capacitor/haptics": "^7.0.0",
    "@capacitor/local-notifications": "^7.0.6",
    "@capacitor/preferences": "^7.0.0",
    "@capacitor/push-notifications": "^7.0.6",
    "@coreui/angular": "^5.5.17",
